# ===== App =====
YWTY_APP_ENV=dev
YWTY_APP_PORT=8080

# ===== Database =====
# 切换驱动时同时调整对应字段（driver: mysql|postgres|sqlite）
YWTY_DATABASE_DRIVER=sqlite
YWTY_DATABASE_PATH=storage/dev.db

# MySQL
# YWTY_DATABASE_DRIVER=mysql
# YWTY_DATABASE_HOST=127.0.0.1
# YWTY_DATABASE_PORT=3306
# YWTY_DATABASE_USERNAME=ywty
# YWTY_DATABASE_PASSWORD=secret
# YWTY_DATABASE_DBNAME=ywty

# PostgreSQL
# YWTY_DATABASE_DRIVER=postgres
# YWTY_DATABASE_HOST=127.0.0.1
# YWTY_DATABASE_PORT=5432
# YWTY_DATABASE_USERNAME=ywty
# YWTY_DATABASE_PASSWORD=secret
# YWTY_DATABASE_DBNAME=ywty
# YWTY_DATABASE_SSLMODE=disable

# ===== Redis =====
YWTY_REDIS_ADDR=127.0.0.1:6379
YWTY_REDIS_PASSWORD=
YWTY_REDIS_DB=0

# ===== Auth =====
YWTY_AUTH_JWT_SECRET=change-me-in-production
YWTY_AUTH_ADMIN_SESSION_SECRET=change-me-too

# ===== Log =====
YWTY_LOG_LEVEL=debug
YWTY_LOG_FORMAT=console
