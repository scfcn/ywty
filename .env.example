# =========================================
# ywty 环境变量模板
# 拷贝为 .env 后按需修改，不拷贝也能用默认值启动
#   cp .env.example .env && docker compose up -d
# =========================================

# --- 必改（生产环境）---
# JWT 密钥（请改为 32+ 位随机字符串）
JWT_SECRET=please-change-me

# 对外访问地址（用于生成图片链接、回调等）
APP_URL=http://localhost:3000

# --- 数据库 ---
# 默认 mysql（启动内置 MySQL 容器）
# 连接宿主机已有 MySQL：DB_HOST=host.docker.internal（并加 --scale mysql=0）
# 本地开发用 sqlite：DB_DRIVER=sqlite（并加 --scale mysql=0）
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=ywty
DB_PASSWORD=secret
DB_NAME=ywty

# --- Redis ---
# 默认内置容器；连接宿主机已有 Redis：REDIS_HOST=host.docker.internal（并加 --scale redis=0）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- 可选 ---
PORT=3000
MYSQL_PORT=3306

# --- 支付驱动（可多选，按需启用）---
# 支付宝
PAY_ALIPAY_APP_ID=
PAY_ALIPAY_PRIVATE_KEY=
PAY_ALIPAY_PUBLIC_KEY=
PAY_ALIPAY_SANDBOX=false

# 微信支付
PAY_WXPAY_APP_ID=
PAY_WXPAY_MCH_ID=
PAY_WXPAY_API_KEY=
PAY_WXPAY_PRIVATE_KEY=
PAY_WXPAY_NOTIFY_URL=

# PayPal
PAY_PAYPAL_CLIENT_ID=
PAY_PAYPAL_SECRET=
PAY_PAYPAL_SANDBOX=true

# Stripe
PAY_STRIPE_SECRET=
PAY_STRIPE_PUBLISH=
PAY_STRIPE_WEBHOOK_SECRET=

# EPay 彩虹聚合
PAY_EPAY_PID=
PAY_EPAY_KEY=
PAY_EPAY_API_URL=

